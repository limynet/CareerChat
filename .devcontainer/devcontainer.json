{
  "name": "Ona",
  "image": "mcr.microsoft.com/devcontainers/universal:4.0.1-noble",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.10"
    }
  },
  "postCreateCommand": "bash .devcontainer/secrets.sh && pip install -r requirements.txt 2>/dev/null || true",
  "postStartCommand": "bash .devcontainer/secrets.sh && which opencode >/dev/null 2>&1 || (curl -fsSL https://opencode.ai/install | bash) && (bunx oh-my-openagent install --no-tui --claude=no --openai=no --gemini=no --copilot=no --zai-coding-plan=yes --skip-auth 2>/dev/null || true)",
  "customizations": {
    "vscode": {
      "extensions": [
        "sst-dev.opencode",
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true,
        "terminal.integrated.env.linux": {
          "OPENAI_API_KEY": "${containerEnv:z_ai}",
          "FOUNDRY_URL": "${containerEnv:FOUNDRY_URL}",
          "FOUNDRY_TOKEN": "${containerEnv:FOUNDRY_TOKEN}"
        }
      }
    }
  },
  "remoteEnv": {
    "OPENAI_API_KEY": "${containerEnv:z_ai}",
    "MODEL_NAME": "gpt-5.1"
  }
}
