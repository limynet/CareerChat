{
  "name": "Ona",
  "image": "mcr.microsoft.com/devcontainers/universal:4.0.1-noble",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.10"
    }
  },
  "postCreateCommand": "pip install -r requirements.txt 2>/dev/null || true",
  "postStartCommand": "which opencode >/dev/null 2>&1 || (curl -fsSL https://opencode.ai/install | bash)",
  "customizations": {
    "vscode": {
      "extensions": [
        "sst-dev.opencode",
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true
      }
    }
  }
}
